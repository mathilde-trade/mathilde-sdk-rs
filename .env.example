# Local development example only.
# The SDK itself should prefer explicit config objects over ambient env.
# These values are for examples, manual probes, and smoke tests.

AGGREGATOR_FEED_HTTP_BASE_URL=http://127.0.0.1:18182
AGGREGATOR_FEED_GRPC_BASE_URL=http://127.0.0.1:18092
AGGREGATOR_FEED_WS_BASE_URL=ws://127.0.0.1:18182

# Public feed bearer token for local testing.
AGGREGATOR_FEED_BEARER_TOKEN=
